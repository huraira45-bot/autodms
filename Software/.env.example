# Copy this file to `.env` and fill in real values.
# This file IS committed; .env is NOT (see .gitignore).

# ── Web server ───────────────────────────────────────────────
PORT=5000

# ── Database ────────────────────────────────────────────────
# Windows Authentication is used (no DB_USER / DB_PASSWORD needed) — the
# Node service runs under a Windows account that has access to the DB.
DB_NAME=temp_db1
DB_SERVER=localhost

# ── Auth ────────────────────────────────────────────────────
# CHANGE THIS in production. 32+ random chars recommended.
JWT_SECRET=__CHANGE_ME_TO_A_LONG_RANDOM_STRING__

# ── Twilio WhatsApp (optional) ──────────────────────────────
# Leave blank to run in STUB mode (no real sends, just audit rows).
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
TWILIO_WEBHOOK_VALIDATION_TOKEN=

# ── Public base URL ─────────────────────────────────────────
# Used in WhatsApp message links etc. On the live server this becomes
# something like http://192.168.x.x:5000 (LAN) or your public domain.
PUBLIC_API_BASE=http://localhost:5000
